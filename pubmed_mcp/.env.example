# MinIO credentials (also seed pmid_downloader's S3 client)
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=pmid-pdfs

# Sci-Hub mirrors (in priority order, comma separated)
SCIHUB_MIRRORS=sci-hub.ru,sci-hub.st,sci-hub.se

# true = mimic human pacing (recommended). false = no delays.
HUMAN_DELAY=true

# Optional egress proxy (leave blank to direct-connect)
HTTP_PROXY=
HTTPS_PROXY=

# Logging
RUST_LOG=info,pmid_downloader=debug
